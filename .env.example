# Brain server
PET_NAME=小栈
USER_NAME=主人
MEMORY_DB_PATH=brain/data/pet_memory.db
MEMORY_TOP_K=6
LOG_DIR_PATH=brain/logs

# Optional TTS audio generation. macos_say uses macOS `say` + `afconvert`.
TTS_ENABLED=0
TTS_PROVIDER=macos_say
# Leave empty to use the macOS default voice. Try Tingting, Meijia, or Sinji on macOS.
TTS_VOICE=
TTS_RATE=180
TTS_SAMPLE_RATE=22050
TTS_TIMEOUT_SECONDS=20
TTS_AUDIO_DIR_PATH=brain/data/tts
TTS_PUBLIC_BASE_URL=

# OpenAI-compatible LLM. Leave empty to use local fallback behavior.
LLM_BASE_URL=https://api.openai.com/v1
LLM_API_KEY=
LLM_MODEL=gpt-4.1-mini
LLM_TIMEOUT_SECONDS=30

# Device auth. Set the same value in device/secrets.h when you enable it.
DEVICE_SHARED_SECRET=
